{
  "$comment": "Pre-approved permissions for the video-explainer tool. Installed once during setup, then copied into every video project. Audit this file anytime in the Claude Code /permissions panel.",
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(test:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(date:*)",
      "Bash(pwd)",
      "Bash(uname:*)",
      "Bash(command:*)",
      "Bash(file:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",

      "Bash(mkdir -p:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod +x:*)",

      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf ~/.video-explainer/*)",
      "Bash(rm -rf ~/Videos/explainers/*)",
      "Bash(rm -rf /tmp/*)",
      "Bash(rm -rf $PROJECT_DIR:*)",

      "Bash(curl https://*)",
      "Bash(curl -L https://*)",
      "Bash(curl -sL https://*)",
      "Bash(curl -sSL https://*)",
      "Bash(curl -o:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",

      "Bash(unzip:*)",
      "Bash(tar:*)",
      "Bash(xattr:*)",

      "Bash(npx hyperframes:*)",
      "Bash(npx skills:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(node:*)",

      "Bash(python3 ~/.video-explainer/*)",
      "Bash(/opt/anaconda3/bin/python3:*)",
      "Bash(/opt/anaconda3/bin/ffmpeg:*)",
      "Bash(/opt/anaconda3/bin/ffprobe:*)",
      "Bash(~/.video-explainer/bin/ffmpeg:*)",
      "Bash(~/.video-explainer/bin/ffprobe:*)",

      "Bash(say:*)",
      "Bash(espeak-ng:*)",

      "Bash(lsof:*)",
      "Bash(ps aux:*)",
      "Bash(ps -ef:*)",
      "Bash(kill:*)",
      "Bash(sleep:*)",

      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git rev-parse:*)",
      "Bash(git clone https://github.com/*)",

      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(nvm:*)",

      "Read(~/.video-explainer/**)",
      "Read(~/Videos/explainers/**)",
      "Edit(~/Videos/explainers/**)",
      "Write(~/Videos/explainers/**)",
      "Edit(~/.video-explainer/**)",
      "Write(~/.video-explainer/**)",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebFetch(domain:api.elevenlabs.io)",
      "WebFetch(domain:fonts.googleapis.com)",
      "WebFetch(domain:fonts.gstatic.com)",
      "WebFetch(domain:evermeet.cx)",
      "WebFetch(domain:johnvansickle.com)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /System:*)",
      "Bash(rm -rf /Library:*)",
      "Bash(rm -rf /usr:*)",
      "Bash(rm -rf /etc:*)",
      "Bash(rm -rf /var:*)",
      "Bash(rm -rf ~/Desktop:*)",
      "Bash(rm -rf ~/Documents:*)",
      "Bash(rm -rf ~/Downloads:*)",
      "Bash(curl http://*)",
      "Bash(wget http://*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(eval:*)",
      "Bash(exec:*)",
      "Bash(:(){:|:&};:)",
      "Bash(launchctl:*)",
      "Bash(systemctl:*)",
      "Bash(crontab:*)",
      "Edit(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Read(~/.aws/**)",
      "Edit(/etc/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)"
    ]
  }
}
